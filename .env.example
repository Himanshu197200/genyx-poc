# ── Genyx POC v2 ── environment variables ────────────────────────────────────
# Copy this to .env and fill in real values. Never commit .env to git.

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend
JWT_ISS=https://auth.genyx.local
JWT_KID=genyx-2026-05

# Database (matches docker-compose.yml)
DATABASE_URL=postgres://genyx:genyxsecret@localhost:5432/genyx

# Expo / Mobile
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_BACKEND_URL=http://localhost:4000
EXPO_PUBLIC_WSS_URL=wss://localhost:8884
